        { method: 'PUT', path: '/api/templates/{name}', desc: 'Update existing template', auth: true, body: 'Same as POST', response: 'Updated template' },
        { method: 'DELETE', path: '/api/templates/{name}', desc: 'Delete template', auth: true, response: '204 No Content' },
        { method: 'POST', path: '/api/validate', desc: 'Validate JSON against a template', auth: true, body: '{ "templateName": "...", "jsonPayload": "...", "stopOnFirstError": false }', response: 'ValidationResponse' },
        { method: 'GET', path: '/api/validate/types', desc: 'List all validator types', auth: true, response: 'Categories + validators array', query: '?category=SAP+%2F+OData' },
        { method: 'POST', path: '/mcp', desc: 'MCP JSON-RPC endpoint (tools + resources)', auth: false, body: '{ "jsonrpc": "2.0", "method": "tools/list", "id": 1 }', response: 'MCP JSON-RPC response' },
