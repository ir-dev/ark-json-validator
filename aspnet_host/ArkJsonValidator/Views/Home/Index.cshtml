// ========== Rule Management ==========
function addRuleForField(path) {
    document.getElementById('ruleFieldPath').value = path;
    document.getElementById('ruleOrder').value = fieldRules.length + 1;
    openAddRuleModal();
}

function openAddRuleModal() {
    editingRuleIndex = -1;
    document.getElementById('ruleFieldPath').value = document.getElementById('ruleFieldPath').value || '';
    document.getElementById('ruleValidatorType').value = '';
    document.getElementById('ruleErrorMessage').value = '';
    document.getElementById('ruleIsRequired').checked = true;
    document.getElementById('ruleOrder').value = fieldRules.length + 1;
    document.getElementById('paramFields').innerHTML = '';
    document.getElementById('validatorDescription').classList.add('d-none');
    new bootstrap.Modal('#addRuleModal').show();
}

function onValidatorTypeChange() {
    const type = document.getElementById('ruleValidatorType').value;
    const info = allValidatorTypes.find(v => v.type === type);
    const desc = document.getElementById('validatorDescription');
    const params = document.getElementById('paramFields');

    if (!info) { desc.classList.add('d-none'); params.innerHTML = ''; return; }

    desc.classList.remove('d-none');
    desc.innerHTML = `<i class="bi bi-info-circle me-1"></i><strong>${info.displayName}</strong> — ${info.description}${info.exampleValue ? ` <span class="text-muted ms-2">e.g. <code>${escHtml(info.exampleValue)}</code></span>` : ''}`;

    params.innerHTML = info.parameters.length === 0 ? '' : `
      <div class="col-12"><span class="section-header">Parameters</span>
        <div class="row g-2 mt-0">
          ${info.parameters.map(p => `
            <div class="col-md-4">
              <label class="form-label small">${p.name} ${p.required ? '<span class="text-danger">*</span>' : '<span class="text-muted">(optional)</span>'}</label>
              ${p.type === 'boolean' ? `
                <select class="form-select form-select-sm" id="param_${p.name}">
                  <option value="">default</option><option value="true">true</option><option value="false">false</option>
                </select>` : p.type === 'array' ? `
                <input type="text" class="form-control form-control-sm" id="param_${p.name}" placeholder="${p.description} (comma-separated)">` : `
                <input type="${p.type === 'number' ? 'number' : 'text'}" class="form-control form-control-sm" id="param_${p.name}"
                  placeholder="${p.defaultValue !== undefined ? 'Default: ' + p.defaultValue : p.description}">
              `}
              <div class="form-text">${p.description}</div>
            </div>`).join('')}
        </div>
      </div>`;
}

function confirmAddRule() {
    const path = document.getElementById('ruleFieldPath').value.trim();
    const type = document.getElementById('ruleValidatorType').value;
    if (!path) { toast('Field path is required', 'warning'); return; }
    if (!type) { toast('Validator type is required', 'warning'); return; }

    const info = allValidatorTypes.find(v => v.type === type);
    const parameters = {};
    info?.parameters.forEach(p => {
        const el = document.getElementById(`param_${p.name}`);
        if (el?.value) {
            if (p.type === 'number') parameters[p.name] = Number(el.value);
            else if (p.type === 'boolean') parameters[p.name] = el.value === 'true';
            else if (p.type === 'array') parameters[p.name] = el.value.split(',').map(s => s.trim());
            else parameters[p.name] = el.value;
        }
    });

    const rule = {
        fieldPath: path,
        validatorType: type,
        parameters: Object.keys(parameters).length > 0 ? parameters : null,
        errorMessage: document.getElementById('ruleErrorMessage').value.trim(),
        isRequired: document.getElementById('ruleIsRequired').checked,
        order: parseInt(document.getElementById('ruleOrder').value) || fieldRules.length + 1
    };

    if (editingRuleIndex >= 0) fieldRules[editingRuleIndex] = rule;
    else fieldRules.push(rule);

    bootstrap.Modal.getInstance('#addRuleModal').hide();
    renderRulesList();
    toast(`Rule added: ${path} → ${type}`);
}

function renderRulesList() {
    const container = document.getElementById('rulesList');
    document.getElementById('ruleCount').textContent = fieldRules.length;
    document.getElementById('rulesEmpty').style.display = fieldRules.length ? 'none' : '';

    const catClass = c => ({ 'General': 'cat-general', 'String': 'cat-string', 'Numeric': 'cat-numeric', 'Format': 'cat-format', 'Date/Time': 'cat-datetime', 'SAP / OData': 'cat-sap' }[c] || 'cat-general');
    const catOf = type => allValidatorTypes.find(v => v.type === type)?.category || 'General';

    container.innerHTML = fieldRules.sort((a,b) => a.order - b.order).map((r, i) => `
      <div class="rule-card d-flex align-items-center gap-2 fade-in">
        <span class="text-muted small" style="min-width:20px">${i+1}</span>
        <code class="text-warning flex-grow-1 text-truncate" style="max-width:180px">${escHtml(r.fieldPath)}</code>
        <span class="validator-chip ${catClass(catOf(r.validatorType))}">${escHtml(r.validatorType)}</span>
        ${!r.isRequired ? '<span class="badge bg-secondary rule-badge">optional</span>' : ''}
        ${r.errorMessage ? `<span class="text-muted text-truncate d-none d-md-inline" style="font-size:11px;max-width:140px">${escHtml(r.errorMessage)}</span>` : ''}
        <div class="ms-auto d-flex gap-1">
          <button class="btn btn-sm btn-outline-secondary py-0 px-1" onclick="editRule(${i})" title="Edit"><i class="bi bi-pencil" style="font-size:11px"></i></button>
          <button class="btn btn-sm btn-outline-danger py-0 px-1" onclick="removeRule(${i})" title="Remove"><i class="bi bi-x-lg" style="font-size:11px"></i></button>
        </div>
      </div>`).join('');
}

function editRule(idx) {
    editingRuleIndex = idx;
    const r = fieldRules[idx];
    document.getElementById('ruleFieldPath').value = r.fieldPath;
    document.getElementById('ruleValidatorType').value = r.validatorType;
    onValidatorTypeChange();
    document.getElementById('ruleErrorMessage').value = r.errorMessage;
    document.getElementById('ruleIsRequired').checked = r.isRequired;
    document.getElementById('ruleOrder').value = r.order;
    if (r.parameters) {
        const info = allValidatorTypes.find(v => v.type === r.validatorType);
        info?.parameters.forEach(p => {
            const el = document.getElementById(`param_${p.name}`);
            if (el && r.parameters[p.name] !== undefined) el.value = Array.isArray(r.parameters[p.name]) ? r.parameters[p.name].join(', ') : r.parameters[p.name];
        });
    }
    new bootstrap.Modal('#addRuleModal').show();
}

function removeRule(idx) {
    fieldRules.splice(idx, 1);
    renderRulesList();
}

// ========== Group Rules ==========
function addGroupRule() { new bootstrap.Modal('#groupRuleModal').show(); }

function confirmAddGroupRule() {
    const name = document.getElementById('grGroupName').value.trim();
    const type = document.getElementById('grGroupType').value;
    const paths = document.getElementById('grFieldPaths').value.split('\n').map(s=>s.trim()).filter(Boolean);
    if (!name || !type || !paths.length) { toast('Group name, type, and fields are required', 'warning'); return; }
    groupRules.push({ groupName: name, groupValidatorType: type, fieldPaths: paths, errorMessage: document.getElementById('grErrorMessage').value });
    bootstrap.Modal.getInstance('#groupRuleModal').hide();
    renderGroupRules();
    toast(`Group rule "${name}" added`);
}

function renderGroupRules() {
    const section = document.getElementById('groupRulesSection');
    section.classList.toggle('d-none', groupRules.length === 0);
    document.getElementById('groupRulesList').innerHTML = groupRules.map((g, i) => `
      <div class="rule-card d-flex align-items-center gap-2">
        <i class="bi bi-diagram-2 text-warning"></i>
        <strong class="small">${escHtml(g.groupName)}</strong>
        <span class="badge bg-warning text-dark">${escHtml(g.groupValidatorType)}</span>
        <span class="text-muted small">${g.fieldPaths.join(', ')}</span>
        <button class="btn btn-sm btn-outline-danger py-0 px-1 ms-auto" onclick="removeGroupRule(${i})"><i class="bi bi-x-lg" style="font-size:11px"></i></button>
      </div>`).join('');
}

function removeGroupRule(i) { groupRules.splice(i,1); renderGroupRules(); }

// ========== Save Template ==========
async function saveTemplate() {
    const name = document.getElementById('templateName').value.trim();
    if (!name) { toast('Template name is required', 'warning'); return; }
    if (!fieldRules.length && !groupRules.length) { toast('Add at least one rule', 'warning'); return; }

    const payload = { name, description: document.getElementById('templateDescription').value, tags: document.getElementById('templateTags').value, fieldRules, groupRules };
    const existing = allTemplates.find(t => t.name === name);
    const url = existing ? `/api/templates/${encodeURIComponent(name)}` : '/api/templates';
    const method = existing ? 'PUT' : 'POST';

    const res = await fetch(url, { method, headers: { ...apiHeaders(), 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    if (res.ok || res.status === 201) {
        toast(`Template "${name}" ${existing ? 'updated' : 'saved'}!`, 'success');
        await loadTemplates();
    } else {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        toast(err.error || 'Save failed', 'danger');
    }
}

function clearBuilder() {
    fieldRules = []; groupRules = [];
    document.getElementById('templateName').value = '';
    document.getElementById('templateDescription').value = '';
    document.getElementById('templateTags').value = '';
    sampleJsonCM.setValue('{\n  "id": 1\n}');
    document.getElementById('fieldTree').innerHTML = '<div class="text-center py-4 text-muted small">Paste JSON above and click Explore Fields</div>';
    renderRulesList(); renderGroupRules();
}

function previewTemplate() {
    const payload = {
        name: document.getElementById('templateName').value || '(unnamed)',
        description: document.getElementById('templateDescription').value,
        fieldRules, groupRules
    };
    document.getElementById('previewContent').innerHTML = `<pre class="api-snippet">${escHtml(JSON.stringify(payload, null, 2))}</pre>`;
    new bootstrap.Modal('#previewModal').show();
}

// ========== Validation ==========
async function runValidation() {
    const template = document.getElementById('validateTemplate').value;
    if (!template) { toast('Select a template', 'warning'); return; }
    let json;
    try { JSON.parse(validateJsonCM.getValue()); json = validateJsonCM.getValue(); } catch { toast('Invalid JSON', 'danger'); return; }

    const btn = document.querySelector('[onclick="runValidation()"]');
    const spinner = document.getElementById('validateSpinner');
    btn.disabled = true; spinner.classList.remove('d-none');

    try {
        const res = await fetch('/api/validate', {
            method: 'POST',
            headers: { ...apiHeaders(), 'Content-Type': 'application/json' },
            body: JSON.stringify({ templateName: template, jsonPayload: json, stopOnFirstError: document.getElementById('stopOnFirst').checked })
        });
        const result = await res.json();
        renderValidationResult(result);
    } finally { btn.disabled = false; spinner.classList.add('d-none'); }
}

function renderValidationResult(result) {
    const container = document.getElementById('validationResults');
    const icon = result.isValid ? '<i class="bi bi-shield-check fs-1 text-success"></i>' : '<i class="bi bi-shield-x fs-1 text-danger"></i>';
    const status = result.isValid
        ? '<div class="alert alert-success py-2 px-3 mb-2 fw-semibold"><i class="bi bi-check-circle me-2"></i>Validation PASSED</div>'
        : `<div class="alert alert-danger py-2 px-3 mb-2 fw-semibold"><i class="bi bi-x-circle me-2"></i>Validation FAILED — ${result.errors.length} error(s)</div>`;

    container.innerHTML = `
      <div class="text-center mb-3">${icon}</div>
      ${status}
      <div class="d-flex justify-content-between small text-muted mb-2">
        <span>Template: <strong>${escHtml(result.templateName)}</strong></span>
        <span>${result.totalRulesChecked} rules checked</span>
      </div>
      ${result.errors.map(e => `
        <div class="result-item fail fade-in">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-x-circle-fill text-danger"></i>
            <code class="text-warning">${escHtml(e.fieldPath)}</code>
            ${e.groupName ? `<span class="badge bg-warning text-dark">group: ${escHtml(e.groupName)}</span>` : ''}
          </div>
          <div class="text-danger small mt-1 ms-4">${escHtml(e.errorMessage)}</div>
          ${e.actualValue !== null && e.actualValue !== undefined ? `<div class="text-muted ms-4" style="font-size:11px">Got: <code>${escHtml(JSON.stringify(e.actualValue))}</code></div>` : ''}
        </div>`).join('')}
      ${result.warnings.map(w => `<div class="alert alert-warning py-1 px-2 small"><i class="bi bi-exclamation-triangle me-1"></i>${escHtml(w)}</div>`).join('')}
      ${result.isValid ? '<div class="result-item pass text-center"><i class="bi bi-check-all me-2"></i>All rules passed successfully</div>' : ''}`;
}

