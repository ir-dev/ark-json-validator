          ${e.body ? `<div class="mt-1"><span class="text-muted" style="font-size:10px">Body: </span><code class="text-primary" style="font-size:10px">${escHtml(e.body)}</code></div>` : ''}
          <div class="mt-1"><span class="text-muted" style="font-size:10px">Response: </span><span class="text-muted" style="font-size:10px">${e.response}</span></div>
        </div>
      </div>`).join('');
}

function copyMcpConfig() {
    const config = JSON.stringify({ mcpServers: { "ark-validator": { url: window.location.origin + '/mcp', transport: 'http' } } }, null, 2);
    navigator.clipboard.writeText(config).then(() => toast('MCP config copied!', 'success'));
}

// ========== Helpers ==========
function apiHeaders() {
    return { 'Authorization': 'Basic ' + btoa('admin:ark2024!') };
}

function escHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toast(msg, type = 'info') {
    const id = 'toast_' + Date.now();
    const icons = { success: 'bi-check-circle-fill text-success', danger: 'bi-x-circle-fill text-danger', warning: 'bi-exclamation-triangle-fill text-warning', info: 'bi-info-circle-fill text-primary' };
    document.getElementById('toastContainer').insertAdjacentHTML('beforeend', `
      <div id="${id}" class="toast show align-items-center border-0 mb-2 fade-in" style="background:var(--ark-surface);border:1px solid var(--ark-border)!important">
        <div class="d-flex align-items-center gap-2 px-3 py-2">
          <i class="bi ${icons[type] || icons.info}"></i>
          <span class="small flex-grow-1">${escHtml(msg)}</span>
          <button type="button" class="btn-close btn-close-white btn-sm ms-2" onclick="document.getElementById('${id}').remove()"></button>
        </div>
      </div>`);
    setTimeout(() => document.getElementById(id)?.remove(), 4000);
}
</script>
}
