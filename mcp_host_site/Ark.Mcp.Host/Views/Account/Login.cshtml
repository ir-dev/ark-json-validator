@model SendOtpViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-primary text-white text-center rounded-top-4 py-4">
                <i class="fas fa-envelope fa-3x mb-2"></i>
                <h3 class="mb-0">Welcome Back</h3>
                <p class="mb-0 opacity-75">Sign in with Email & OTP</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="SendOtp" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="developer@example.com" autofocus />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <div class="form-text">We'll send a one-time password to this email.</div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-paper-plane"></i> Send OTP
                    </button>
                </form>

                <hr class="my-4" />

                <div class="text-center text-muted small">
                    <p class="mb-0">New to MCP Hub? You'll be automatically registered when you sign in.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}