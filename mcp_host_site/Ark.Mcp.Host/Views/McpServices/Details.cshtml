@model McpService
@{
    ViewData["Title"] = "Service Details - " + Model.Name;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="McpServices" asp-action="Browse">Browse Services</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h2 class="mb-1">
                                <i class="fas fa-microchip text-primary me-2"></i>@Model.Name
                            </h2>
                            <div class="mb-2">
                                <span class="badge bg-secondary me-2">
                                    <i class="fas fa-tag"></i> @(string.IsNullOrEmpty(Model.Domain) ? "Uncategorized" : Model.Domain)
                                </span>
                                <span class="badge bg-info text-dark">
                                    <i class="fas fa-lock"></i> Auth: @Model.AuthenticationType
                                </span>
                            </div>
                        </div>
                        @if (User.Identity?.IsAuthenticated == true && Model.OwnerUserId == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                        {
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="mb-4">
                        <h5><i class="fas fa-align-left text-secondary me-2"></i>Description</h5>
                        <p class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded-3">
                                <i class="fas fa-link text-primary me-2"></i>
                                <strong>Endpoint URL</strong><br />
                                <a href="@Model.EndpointUrl" target="_blank" class="text-break">@Model.EndpointUrl</a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded-3">
                                <i class="fas fa-user-circle text-primary me-2"></i>
                                <strong>Owner</strong><br />
                                @Model.Owner.Email
                            </div>
                        </div>
                        @if (Model.AuthenticationType == "ApiKey" && !string.IsNullOrEmpty(Model.ApiKeyHeader))
                        {
                            <div class="col-md-6">
                                <div class="bg-light p-3 rounded-3">
                                    <i class="fas fa-key text-primary me-2"></i>
                                    <strong>API Key Header</strong><br />
                                    <code>@Model.ApiKeyHeader</code>
                                </div>
                            </div>
                        }
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded-3">
                                <i class="far fa-calendar-alt text-primary me-2"></i>
                                <strong>Registered</strong><br />
                                @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' h:mm tt")
                            </div>
                        </div>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div class="col-md-6">
                                <div class="bg-light p-3 rounded-3">
                                    <i class="fas fa-sync-alt text-primary me-2"></i>
                                    <strong>Last Updated</strong><br />
                                    @Model.UpdatedAt.Value.ToString("MMMM dd, yyyy 'at' h:mm tt")
                                </div>
                            </div>
                        }
                    </div>

                    <div class="alert alert-primary mt-3" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Integration Info</strong><br />
                        To use this MCP service, point your MCP client to the endpoint URL above.
                        @if (Model.AuthenticationType != "None")
                        {
                            <text>This service requires <strong>@Model.AuthenticationType</strong> authentication. </text>
                            @if (Model.AuthenticationType == "ApiKey")
                            {
                                <text>Include the API key in the <code>@Model.ApiKeyHeader</code> header.</text>
                            }
                        }
                        else
                        {
                            <text>This is a public service – no authentication required.</text>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="mb-0"><i class="fas fa-chart-simple"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Model.EndpointUrl" target="_blank" class="btn btn-primary">
                            <i class="fas fa-external-link-alt"></i> Test Endpoint
                        </a>
                        <button class="btn btn-outline-secondary" onclick="copyToClipboard('@Model.EndpointUrl')">
                            <i class="fas fa-copy"></i> Copy Endpoint URL
                        </button>
                        <a asp-controller="McpServices" asp-action="Browse" class="btn btn-outline-info">
                            <i class="fas fa-globe"></i> Browse Other Services
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="mb-0"><i class="fas fa-share-alt"></i> Share Service</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-around">
                        <a href="#" onclick="shareService('twitter')" class="text-decoration-none">
                            <i class="fab fa-twitter fa-2x text-primary"></i>
                        </a>
                        <a href="#" onclick="shareService('linkedin')" class="text-decoration-none">
                            <i class="fab fa-linkedin fa-2x text-primary"></i>
                        </a>
                        <a href="#" onclick="shareService('email')" class="text-decoration-none">
                            <i class="fas fa-envelope fa-2x text-secondary"></i>
                        </a>
                    </div>
                    <hr />
                    <div class="input-group mt-2">
                        <input type="text" id="shareUrl" class="form-control" value="@(Context.Request.Scheme + "://" + Context.Request.Host + Url.Action("Details", new { id = Model.Id }))" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('#shareUrl')">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyToClipboard(elementIdOrUrl) {
            let text;
            if (typeof elementIdOrUrl === 'string' && elementIdOrUrl.startsWith('#')) {
                text = document.querySelector(elementIdOrUrl).value;
            } else {
                text = elementIdOrUrl;
            }
            navigator.clipboard.writeText(text).then(() => {
                alert('Copied to clipboard!');
            }).catch(() => {
                alert('Failed to copy');
            });
        }

        function shareService(platform) {
            const url = encodeURIComponent(window.location.href);
            const title = encodeURIComponent('@Model.Name - MCP Service');
            let shareUrl = '';
            switch(platform) {
                case 'twitter':
                    shareUrl = `https://twitter.com/intent/tweet?text=${title}&url=${url}`;
                    break;
                case 'linkedin':
                    shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
                    break;
                case 'email':
                    shareUrl = `mailto:?subject=${title}&body=Check out this MCP service: ${url}`;
                    break;
            }
            if (shareUrl) window.open(shareUrl, '_blank');
        }
    </script>
}