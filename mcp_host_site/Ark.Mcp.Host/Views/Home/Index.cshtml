@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>ARK‑MCP Discovery Platform | Unified Hub for MCP Services</title>
  <!-- Google Fonts & Font Awesome -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
      color: #0f172a;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* header & nav */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      flex-wrap: wrap;
      gap: 16px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-icon {
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      width: 42px;
      height: 42px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
    }

    .logo-icon i {
      font-size: 24px;
      color: white;
    }

    .logo-text h1 {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.01em;
      background: linear-gradient(135deg, #1e293b, #3b82f6);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .logo-text span {
      font-size: 0.8rem;
      font-weight: 500;
      color: #475569;
      display: block;
      letter-spacing: 0.3px;
    }

    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
    }

    .nav-links a {
      text-decoration: none;
      font-weight: 600;
      color: #1e293b;
      transition: all 0.2s;
    }

    .nav-links a:hover {
      color: #2563eb;
    }

    .btn-outline-light {
      background: transparent;
      border: 1.5px solid #cbd5e1;
      padding: 8px 20px;
      border-radius: 40px;
      font-weight: 600;
    }

    .btn-primary {
      background: linear-gradient(95deg, #2563eb, #4f46e5);
      color: white;
      border: none;
      padding: 10px 28px;
      border-radius: 40px;
      font-weight: 600;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(37, 99, 235, 0.4);
    }

    .btn-secondary {
      background: white;
      border: 1px solid #cbd5e1;
      color: #1e293b;
      padding: 10px 28px;
      border-radius: 40px;
      font-weight: 600;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }

    .btn-secondary:hover {
      border-color: #2563eb;
      color: #2563eb;
      background: #f0f9ff;
    }

    /* hero */
    .hero {
      padding: 60px 0 40px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 48px;
    }

    .hero-content {
      flex: 1;
    }

    .hero-badge {
      background: rgba(37, 99, 235, 0.12);
      display: inline-block;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      color: #2563eb;
      margin-bottom: 24px;
    }

    .hero-content h1 {
      font-size: 3.2rem;
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }

    .gradient-text {
      background: linear-gradient(115deg, #2563eb, #9333ea);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .hero-content p {
      font-size: 1.2rem;
      color: #334155;
      margin-bottom: 32px;
      max-width: 540px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }

    .hero-visual {
      flex: 1;
      background: rgba(255,255,255,0.6);
      backdrop-filter: blur(4px);
      border-radius: 2rem;
      padding: 20px;
      box-shadow: 0 25px 45px -12px rgba(0,0,0,0.15);
      border: 1px solid rgba(255,255,255,0.8);
    }

    .demo-card {
      background: white;
      border-radius: 28px;
      padding: 24px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .otp-demo {
      display: flex;
      gap: 12px;
      align-items: center;
      margin: 16px 0;
      flex-wrap: wrap;
    }

    .otp-demo input {
      flex: 1;
      padding: 14px 18px;
      border-radius: 60px;
      border: 1px solid #e2e8f0;
      font-size: 1rem;
      background: #f9fafb;
    }

    .small-text {
      font-size: 0.8rem;
      color: #64748b;
    }

    /* features section */
    .section {
      padding: 80px 0;
    }

    .section-title {
      text-align: center;
      margin-bottom: 56px;
    }

    .section-title h2 {
      font-size: 2.4rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .section-title p {
      color: #475569;
      max-width: 680px;
      margin: 0 auto;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
    }

    .feature-card {
      background: white;
      padding: 32px 24px;
      border-radius: 32px;
      transition: all 0.25s ease;
      box-shadow: 0 5px 15px rgba(0,0,0,0.02);
      border: 1px solid #eef2ff;
    }

    .feature-card:hover {
      transform: translateY(-6px);
      border-color: #c7d2fe;
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1);
    }

    .feature-icon {
      background: #eef2ff;
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 20px;
      margin-bottom: 24px;
      color: #2563eb;
      font-size: 28px;
    }

    .feature-card h3 {
      font-size: 1.5rem;
      margin-bottom: 12px;
    }

    /* steps */
    .steps {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 24px;
      margin-top: 32px;
    }

    .step-item {
      flex: 1;
      background: white;
      border-radius: 28px;
      padding: 28px;
      text-align: center;
      border: 1px solid #e2e8f0;
    }

    .step-number {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, #2563eb, #4f46e5);
      color: white;
      font-weight: 800;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 60px;
      margin: 0 auto 20px;
    }

    /* cta */
    .cta-section {
      background: linear-gradient(105deg, #0f172a 0%, #1e293b 100%);
      border-radius: 48px;
      padding: 56px 40px;
      color: white;
      text-align: center;
      margin-bottom: 48px;
    }

    .cta-section h3 {
      font-size: 2rem;
      margin-bottom: 16px;
    }

    /* footer */
    footer {
      border-top: 1px solid #e2e8f0;
      padding: 40px 0 32px;
      text-align: center;
      color: #475569;
    }

    @@media (max-width: 768px) {
      .hero-content h1 {
        font-size: 2.4rem;
      }
      .navbar {
        flex-direction: column;
        text-align: center;
      }
      .hero-actions {
        justify-content: center;
      }
      .hero-content {
        text-align: center;
      }
      .hero-content p {
        margin-left: auto;
        margin-right: auto;
      }
      .section-title h2 {
        font-size: 1.9rem;
      }
      .step-item {
        min-width: 240px;
      }
    }
  </style>
</head>
<body>

<div class="container">
  <!-- Navigation -->
  <div class="navbar">
    <div class="logo">
      <div class="logo-icon">
        <i class="fas fa-cube"></i>
      </div>
      <div class="logo-text">
        <h1>ARK‑MCP Discovery</h1>
        <span>Model Context Protocol Hub</span>
      </div>
    </div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#developers">For Devs</a>
      <a href="#howitworks">How it works</a>
      <a href="#" class="btn-outline-light">Documentation</a>
    </div>
  </div>

  <!-- Hero section -->
  <div class="hero">
    <div class="hero-content">
      <div class="hero-badge">
        <i class="fas fa-microchip"></i> Next‑gen MCP registry
      </div>
      <h1>
        Discover, host & share<br>
        <span class="gradient-text">MCP Servers</span> without complexity
      </h1>
      <p>
        ARK‑MCP Discovery is the unified platform where AI engineers, tool builders, and developers 
        register, manage, and discover Model Context Protocol services — secured by passwordless 
        <strong>Email + OTP</strong> authentication.
      </p>
      <div class="hero-actions">
        <button class="btn-primary" onclick="window.location.href='/Home/Landing'">
          <i class="fas fa-paper-plane"></i> Login
        </button>
        <a href="#" class="btn-secondary" onclick="event.preventDefault();alert('📡 Browse public MCP services: weather, database connectors, AI agents & more.')">
          <i class="fas fa-globe"></i> Browse services
        </a>
      </div>
      <div class="small-text" style="margin-top: 32px;">
        <i class="fas fa-shield-alt"></i> No passwords • OTP via email • instant sign‑up
      </div>
    </div>
  </div>

  <!-- Features grid -->
  <div class="section" id="features">
    <div class="section-title">
      <h2>Everything you need to <span class="gradient-text">unify MCP ecosystem</span></h2>
      <p>Built for developers who build AI agents, LLM tools and context-aware applications</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-envelope-open-text"></i></div>
        <h3>Email + OTP Auth</h3>
        <p>No more password fatigue. Sign in with a magic one‑time password delivered to your inbox. Auto‑registration on first login.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-server"></i></div>
        <h3>Register MCP Services</h3>
        <p>Host any MCP server: add name, endpoint, description, domain and choose auth type (None, API Key, OAuth). Full CRUD ownership.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-search"></i></div>
        <h3>Discover community hubs</h3>
        <p>Browse public MCP services from other developers. Filter by domain, search by keywords, view details and integration examples.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-code-branch"></i></div>
        <h3>Developer-first registry</h3>
        <p>API keys support, custom headers, domain tagging. Showcase your MCP server to the AI tools ecosystem.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-chart-line"></i></div>
        <h3>Analytics & visibility</h3>
        <p>Track your service adoption, get insights and make your MCP server discoverable by agents and LLM platforms.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-plug"></i></div>
        <h3>Extensible architecture</h3>
        <p>Built on ASP.NET Core & EF Core. Fully open for custom authentication providers and integration with any MCP client.</p>
      </div>
    </div>
  </div>

  <!-- For developers: how to register services -->
  <div class="section" id="developers" style="padding-top: 0;">
    <div class="section-title">
      <h2>🎯 For developers & service owners</h2>
      <p>Publish your MCP server in minutes, control who accesses it, and become part of the global MCP network.</p>
    </div>
    <div class="steps">
      <div class="step-item">
        <div class="step-number">1</div>
        <h4>Sign up with email</h4>
        <p class="small-text">Get a 6‑digit OTP, instantly registered & authenticated.</p>
      </div>
      <div class="step-item">
        <div class="step-number">2</div>
        <h4>Register your MCP service</h4>
        <p class="small-text">Fill endpoint URL, choose auth method (None / ApiKey / OAuth) + metadata.</p>
      </div>
      <div class="step-item">
        <div class="step-number">3</div>
        <h4>Share & grow</h4>
        <p class="small-text">Your service appears in the discovery feed. AI developers can integrate immediately.</p>
      </div>
    </div>

    <div style="background: linear-gradient(115deg, #eff6ff, #ffffff); border-radius: 28px; padding: 32px; margin-top: 48px; border: 1px solid #d9e6ff;">
      <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between;">
        <div>
          <i class="fas fa-microchip" style="font-size: 2rem; color: #2563eb;"></i>
          <h3 style="margin-top: 10px;">Example MCP service registration</h3>
          <p style="color: #334155;">"WeatherMCP" • Endpoint: https://weather-api.mcp/v1 • Auth: API Key (X-Weather-Key) • Domain: Weather Intelligence</p>
        </div>
        <button class="btn-primary" onclick="alert('📦 ARK‑MCP Dashboard: you can edit, delete, and manage API key headers for your registered services.')" style="white-space: nowrap;">
          <i class="fas fa-plus-circle"></i> Register now
        </button>
      </div>
    </div>
  </div>

  <!-- How it works (end user + dev) -->
  <div class="section" id="howitworks">
    <div class="section-title">
      <h2>⚡ Seamless workflow: <span class="gradient-text">email → OTP → discover</span></h2>
      <p>From authentication to MCP integration, ARK‑MCP makes everything straightforward.</p>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 30px;">
      <div style="flex: 1; background: white; border-radius: 32px; padding: 28px;">
        <i class="fas fa-user-check" style="font-size: 32px; color: #2563eb;"></i>
        <h3 style="margin: 16px 0 12px;">For consumers / AI agents</h3>
        <ul style="list-style: none; padding-left: 0;">
          <li style="margin-bottom: 12px;"><i class="fas fa-check-circle" style="color: #10b981; width: 24px;"></i> 1. Enter email → receive OTP</li>
          <li style="margin-bottom: 12px;"><i class="fas fa-check-circle" style="color: #10b981; width: 24px;"></i> 2. Verify code → instant dashboard</li>
          <li style="margin-bottom: 12px;"><i class="fas fa-check-circle" style="color: #10b981; width: 24px;"></i> 3. Browse hundreds of MCP servers</li>
          <li><i class="fas fa-check-circle" style="color: #10b981; width: 24px;"></i> 4. Integrate endpoints into your LLM workflow</li>
        </ul>
      </div>
      <div style="flex: 1; background: white; border-radius: 32px; padding: 28px;">
        <i class="fas fa-chalkboard-user" style="font-size: 32px; color: #7c3aed;"></i>
        <h3 style="margin: 16px 0 12px;">For service publishers</h3>
        <ul style="list-style: none; padding-left: 0;">
          <li style="margin-bottom: 12px;"><i class="fas fa-shield-alt"></i> Own your endpoints & authentication spec</li>
          <li style="margin-bottom: 12px;"><i class="fas fa-chart-simple"></i> Monitor usage stats (roadmap)</li>
          <li style="margin-bottom: 12px;"><i class="fas fa-edit"></i> Edit service details anytime</li>
          <li><i class="fas fa-users"></i> Connect with AI developers community</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Security + tech note -->
  <div style="background: white; border-radius: 40px; padding: 28px 32px; margin: 20px 0 32px; box-shadow: 0 8px 20px rgba(0,0,0,0.02); border: 1px solid #eef2ff;">
    <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between;">
      <div>
        <i class="fas fa-laptop-code" style="font-size: 36px; color: #2563eb;"></i>
        <h3 style="margin: 8px 0;">Built for extensibility & trust</h3>
        <p>ARK‑MCP Discovery uses ASP.NET Core Identity-free OTP flow, SQLite/PostgreSQL ready, MailKit email delivery, and cookie auth with sliding expiration. Open to contributions & custom MCP gateways.</p>
      </div>
      <div>
        <span style="background: #e6f0ff; padding: 8px 16px; border-radius: 60px; font-weight: 500;"><i class="fab fa-github"></i> Open Core</span>
      </div>
    </div>
  </div>

  <!-- CTA banner -->
  <div class="cta-section">
    <h3>Ready to launch your MCP server?</h3>
    <p style="font-size: 1.1rem; margin-bottom: 28px; opacity: 0.9;">Join a growing network of context protocol innovators. Passwordless, secure, and developer‑centric.</p>
    <div class="hero-actions" style="justify-content: center;">
      <button class="btn-primary" style="background: white; color: #0f172a; box-shadow: none;" onclick="alert('✨ ARK‑MCP early access: email+OTP demo is fully functional. Register your first MCP service today.')">
        <i class="fas fa-rocket"></i> Get early access
      </button>
      <button class="btn-secondary" style="background: rgba(255,255,255,0.12); border-color: #94a3b8; color: white;" onclick="alert('📖 Documentation: REST API for services, metadata schemas, and webhooks coming soon.')">
        Read docs
      </button>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <div style="display: flex; justify-content: center; gap: 32px; flex-wrap: wrap; margin-bottom: 20px;">
      <a href="#" style="text-decoration: none; color: #475569;"><i class="fab fa-twitter"></i> Twitter</a>
      <a href="#" style="text-decoration: none; color: #475569;"><i class="fab fa-github"></i> GitHub</a>
      <a href="#" style="text-decoration: none; color: #475569;"><i class="fas fa-envelope"></i> Contact</a>
      <a href="#" style="text-decoration: none; color: #475569;">Privacy & Terms</a>
    </div>
    <p>© 2026 ARK‑MCP Discovery Platform — Empowering the Model Context Protocol ecosystem. <br>Email + OTP login • Zero‑password architecture • Host your own MCP services.</p>
    <div style="margin-top: 16px; font-size: 0.8rem;">
      <i class="fas fa-shield-heart"></i> Secure by design — OTP expires in 10 minutes, automatic cleanup.
    </div>
  </footer>
</div>

<!-- micro interaction for demo simplicity -->
<script>
  // Simple interactive demo to show OTP concept on hero
  console.log("ARK-MCP Discovery platform UI ready — all features described reflect the ASP.NET Core implementation with email+OTP & MCP service registry.");
</script>
</body>
</html>