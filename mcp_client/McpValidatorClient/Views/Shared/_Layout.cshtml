<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ARK Complaint Intelligence</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/codemirror.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.17/theme/dracula.min.css" />
    <style>
        :root {
            --bg: #0d1117; --surface: #161b22; --surface2: #1c2128;
            --border: #30363d; --accent: #58a6ff; --green: #3fb950;
            --red: #f85149; --yellow: #d29922; --orange: #ffa657;
            --purple: #bc8cff; --muted: #8b949e;
        }
        * { box-sizing: border-box; }
        body { background: var(--bg); color: #e6edf3; font-family: 'Segoe UI', system-ui, sans-serif; margin: 0; }
        .navbar { background: var(--surface) !important; border-bottom: 1px solid var(--border) !important; }
        .navbar-brand { font-weight: 700; font-size: 1.2rem; color: var(--accent) !important; }
        .navbar-brand span { font-size: 10px; color: var(--muted); font-weight: 400; display: block; line-height: 1; }

        /* ── Pipeline stepper ── */
        .pipeline-track { display: flex; flex-direction: column; gap: 0; }
        .pipeline-step { position: relative; display: flex; gap: 16px; padding: 0 0 0 0; }
        .step-connector { display: flex; flex-direction: column; align-items: center; width: 36px; flex-shrink: 0; }
        .step-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 15px; border: 2px solid var(--border); background: var(--surface2); color: var(--muted); flex-shrink: 0; z-index: 1; transition: all .3s; }
        .step-line { width: 2px; flex: 1; min-height: 20px; background: var(--border); margin: 2px 0; transition: background .3s; }
        .step-line.done { background: var(--green); }
        .pipeline-step:last-child .step-line { display: none; }
        .step-content { flex: 1; padding-bottom: 20px; min-width: 0; }
        .step-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; padding-top: 6px; }
        .step-title { font-weight: 600; font-size: 14px; }
        .step-badge { font-size: 10px; padding: 2px 8px; border-radius: 20px; border: 1px solid; font-weight: 600; }
        .step-elapsed { font-size: 11px; color: var(--muted); }
        .step-output { font-size: 13px; color: #e6edf3; }
        .step-error { font-size: 12px; color: var(--red); margin-top: 4px; }
        .step-detail { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; margin-top: 8px; overflow: hidden; }
        .step-detail-header { padding: 6px 12px; font-size: 11px; color: var(--muted); background: var(--surface2); cursor: pointer; display: flex; justify-content: between; align-items: center; }
        .step-detail pre { margin: 0; padding: 10px 12px; font-size: 11.5px; line-height: 1.5; max-height: 260px; overflow-y: auto; color: #e6edf3; }

        /* Step status colors */
        .step-pending  .step-icon { border-color: var(--border); color: var(--muted); }
        .step-running  .step-icon { border-color: var(--accent); color: var(--accent); animation: pulse 1.2s infinite; }
        .step-success  .step-icon { border-color: var(--green); background: rgba(63,185,80,.15); color: var(--green); }
        .step-failed   .step-icon { border-color: var(--red);   background: rgba(248,81,73,.15); color: var(--red); }
        .step-skipped  .step-icon { border-color: var(--border); color: var(--border); }
        .badge-pending  { border-color: var(--border);  color: var(--muted); }
        .badge-running  { border-color: var(--accent);  color: var(--accent); }
        .badge-success  { border-color: var(--green);   color: var(--green); }
        .badge-failed   { border-color: var(--red);     color: var(--red); }
        .badge-skipped  { border-color: var(--border);  color: var(--muted); }

        @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
        @@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
        .fade-in { animation: fadeIn .25s ease; }

        /* ── Cards & common ── */
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; }
        .card-header { background: rgba(255,255,255,.03); border-bottom: 1px solid var(--border); }
        .form-control, textarea { background: var(--bg) !important; border: 1px solid var(--border) !important; color: #e6edf3 !important; }
        .form-control:focus, textarea:focus { border-color: var(--accent) !important; box-shadow: 0 0 0 3px rgba(88,166,255,.15) !important; }
        textarea::placeholder { color: var(--muted) !important; }
        .form-select { background-color: var(--bg) !important; border-color: var(--border) !important; color: #e6edf3 !important; }
        .btn-primary { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
        .btn-primary:hover { background: #4493f8; border-color: #4493f8; color: #000; }
        .btn-outline-secondary { border-color: var(--border); color: var(--muted); }
        .btn-outline-secondary:hover { background: var(--surface2); color: #e6edf3; }
        code { background: rgba(240,246,252,.08); padding: 1px 5px; border-radius: 3px; color: var(--orange); font-size: 90%; }
        .toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; }
        .section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-weight: 600; }

        /* ── Sample complaint chips ── */
        .sample-chip { display: inline-block; padding: 5px 12px; border-radius: 20px; font-size: 12px; cursor: pointer; border: 1px solid var(--border); color: var(--muted); margin: 3px; transition: all .15s; }
        .sample-chip:hover { border-color: var(--accent); color: var(--accent); background: rgba(88,166,255,.08); }

        /* ── Result summary bar ── */
        .result-bar { border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
        .result-bar.success { background: rgba(63,185,80,.1); border: 1px solid rgba(63,185,80,.3); }
        .result-bar.failed  { background: rgba(248,81,73,.1);  border: 1px solid rgba(248,81,73,.3);  }

        /* ── JSON viewer ── */
        .json-viewer { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; font-family: 'Cascadia Code','Fira Code',monospace; font-size: 12px; line-height: 1.6; max-height: 300px; overflow-y: auto; white-space: pre-wrap; word-break: break-all; }
        .json-key { color: #79c0ff; }
        .json-str { color: #a5d6ff; }
        .json-num { color: var(--green); }
        .json-bool { color: var(--orange); }
        .json-null { color: var(--muted); }

        /* ── Flow arrows ── */
        .flow-arrow { text-align: center; color: var(--border); font-size: 18px; padding: 2px 0; }

        /* layout */
        .main-layout { display: grid; grid-template-columns: 440px 1fr; gap: 20px; padding: 20px; min-height: calc(100vh - 60px); }
        @@media (max-width: 900px) { .main-layout { grid-template-columns: 1fr; } }
        .left-panel { display: flex; flex-direction: column; gap: 16px; }
        .right-panel { min-width: 0; }
    </style>
</head>
<body>
    <nav class="navbar px-4" style="height:52px;">
        <a class="navbar-brand" href="/">
            <i class="bi bi-cpu me-2 text-primary"></i>ARK Complaint Intelligence
            <span>Powered by Azure OpenAI + MCP Validator</span>
        </a>
        <div class="d-flex align-items-center gap-3">
            <span id="mcpStatus" class="badge bg-secondary" title="MCP Server connection status">
                <i class="bi bi-circle-fill me-1" style="font-size:7px"></i>MCP Offline
            </span>
            <a href="http://localhost:5000" target="_blank" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-box-arrow-up-right me-1"></i>Validator
            </a>
        </div>
    </nav>

    @RenderBody()

    <div class="toast-container" id="toastContainer"></div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
